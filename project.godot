GardenEffectResolver="*res://game/scripts/garden/garden_effect_resolver.gd"
Bloomchains="*res://game/scripts/garden/bloomchain_manager.gd"
JournalManager="*res://game/scripts/meta/journal_manager.gd"
RunManager="*res://game/scripts/core/run_manager.gd"

